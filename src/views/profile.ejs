<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>My Profile</title>
    <link rel="icon" type="image/png" sizes="32x32" href="/images/uploads/mk-favicon.png">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            background: linear-gradient(135deg, #1a0533 0%, #2d0a4e 50%, #1a0533 100%);
            min-height: 100vh;
        }

        /* ── Navbar ── */
        .navbar {
            background: rgba(255,255,255,0.06);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(255,255,255,0.1);
            padding: 0 32px;
            height: 66px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .navbar-left h2 {
            font-size: 1.1rem;
            font-weight: 700;
            color: #f0e6ff;
        }

        .accounts-btn {
            display: flex;
            align-items: center;
            gap: 6px;
            padding: 8px 18px;
            background: linear-gradient(135deg, #e879f9, #a855f7);
            border: none;
            border-radius: 8px;
            font-size: 0.85rem;
            font-weight: 600;
            color: #fff;
            cursor: pointer;
            text-decoration: none;
            transition: opacity 0.18s, transform 0.1s;
            box-shadow: 0 4px 14px rgba(168,85,247,0.3);
        }

        .accounts-btn:hover { opacity: 0.9; }
        .accounts-btn:active { transform: scale(0.97); }

        /* ── Main ── */
        .main {
            max-width: 620px;
            margin: 48px auto;
            padding: 0 20px;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        /* ── Card ── */
        .card {
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(168,85,247,0.25);
            border-radius: 20px;
            padding: 28px;
            backdrop-filter: blur(8px);
        }

        .card-label {
            font-size: 0.75rem;
            font-weight: 600;
            color: #a855f7;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            margin-bottom: 22px;
        }

        /* ── Profile picture ── */
        .avatar-section {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 16px;
        }

        .avatar-wrap {
            position: relative;
            width: 100px;
            height: 100px;
        }

        .avatar-img {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            object-fit: cover;
            border: 3px solid rgba(232,121,249,0.4);
            box-shadow: 0 0 0 4px rgba(168,85,247,0.15);
        }

        .avatar-fallback {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            background: linear-gradient(135deg, #e879f9, #a855f7);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.2rem;
            font-weight: 700;
            color: #fff;
            border: 3px solid rgba(232,121,249,0.4);
            box-shadow: 0 0 0 4px rgba(168,85,247,0.15);
        }

        .avatar-buttons {
            display: flex;
            gap: 10px;
        }

        .btn-update-img {
            padding: 7px 16px;
            background: rgba(168,85,247,0.15);
            border: 1px solid rgba(168,85,247,0.35);
            border-radius: 8px;
            color: #c4b5fd;
            font-size: 0.82rem;
            font-weight: 500;
            cursor: pointer;
            transition: background 0.18s;
        }

        .btn-update-img:hover { background: rgba(168,85,247,0.25); }

        .btn-delete-img {
            padding: 7px 16px;
            background: rgba(239,68,68,0.1);
            border: 1px solid rgba(239,68,68,0.25);
            border-radius: 8px;
            color: #fca5a5;
            font-size: 0.82rem;
            font-weight: 500;
            cursor: pointer;
            transition: background 0.18s;
        }

        .btn-delete-img:hover { background: rgba(239,68,68,0.2); }

        /* hidden file input */
        #avatar-input { display: none; }

        /* ── Form fields ── */
        .field {
            margin-bottom: 18px;
        }

        .field label {
            display: block;
            font-size: 0.8rem;
            color: #9d7fc4;
            font-weight: 500;
            margin-bottom: 6px;
        }

        .field input {
            width: 100%;
            padding: 10px 14px;
            background: rgba(255,255,255,0.07);
            border: 1px solid rgba(168,85,247,0.3);
            border-radius: 10px;
            color: #f0e6ff;
            font-size: 0.9rem;
            outline: none;
            transition: border-color 0.18s, box-shadow 0.18s;
        }

        .field input:focus {
            border-color: #a855f7;
            box-shadow: 0 0 0 3px rgba(168,85,247,0.15);
        }

        .field input:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .field input::placeholder { color: #6b4f8a; }

        .field .lock-note {
            font-size: 0.74rem;
            color: #6b4f8a;
            margin-top: 5px;
        }

        /* ── Password link ── */
        .password-link {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 0.85rem;
            color: #c4b5fd;
            text-decoration: none;
            padding: 8px 0;
            border-bottom: 1px dashed rgba(196,181,253,0.3);
            transition: color 0.18s;
        }

        .password-link:hover { color: #e879f9; }

        /* ── Save button ── */
        .save-btn {
            width: 100%;
            padding: 13px;
            background: linear-gradient(135deg, #e879f9, #a855f7);
            border: none;
            border-radius: 12px;
            color: #fff;
            font-size: 0.95rem;
            font-weight: 600;
            cursor: pointer;
            transition: opacity 0.18s, transform 0.1s, box-shadow 0.18s;
            box-shadow: 0 4px 20px rgba(168,85,247,0.35);
            margin-top: 8px;
        }

        .save-btn:hover { opacity: 0.9; }
        .save-btn:active { transform: scale(0.98); }

        /* ── Alerts ── */
        .alert {
            padding: 10px 14px;
            border-radius: 8px;
            font-size: 0.83rem;
            margin-bottom: 14px;
            display: none;
        }

        .alert-success { background: rgba(34,197,94,0.12); color: #86efac; border: 1px solid rgba(34,197,94,0.25); }
        .alert-error   { background: rgba(239,68,68,0.12); color: #fca5a5; border: 1px solid rgba(239,68,68,0.25); }
    </style>
</head>
<body>

    <!-- ── Navbar ── -->
    <nav class="navbar">
        <div class="navbar-left">
            <h2>My Profile</h2>
        </div>
        <a href="/accounts" class="accounts-btn">
            ← Accounts
        </a>
    </nav>

    <!-- ── Main ── -->
    <div class="main">

        <div id="alert-success" class="alert alert-success">✓ Profile updated successfully.</div>
        <div id="alert-error" class="alert alert-error">⚠ Something went wrong. Please try again.</div>

        <!-- Profile Settings card -->
        <div class="card">
            <div class="card-label">⚙ Profile Settings</div>
            <p style="font-size:0.85rem; color:#9d7fc4; margin-bottom:24px;">Update your name and profile picture. Email cannot be changed.</p>

            <!-- Avatar -->
            <div class="avatar-section" style="margin-bottom:28px;">
                <% if (typeof user !== 'undefined' && user.profilePicture) { %>
                    <img src="<%= user.profilePicture %>" alt="Profile" class="avatar-img" id="avatar-preview"/>
                <% } else { %>
                    <div class="avatar-fallback" id="avatar-preview">
                        <%= typeof user !== 'undefined' ? user.name.charAt(0).toUpperCase() : 'U' %>
                    </div>
                <% } %>

                <input type="file" id="avatar-input" accept="image/*" onchange="previewImage(event)" />

                <div class="avatar-buttons">
                    <button class="btn-update-img" onclick="document.getElementById('avatar-input').click()">
                        📷 Upload Image
                    </button>
                    <button class="btn-delete-img" onclick="deleteImage()">
                        🗑 Delete Image
                    </button>
                </div>
            </div>

            <!-- Name -->
            <div class="field">
                <label for="name">Full Name</label>
                <input
                    type="text"
                    id="name"
                    name="name"
                    value="<%= typeof user !== 'undefined' ? user.name : '' %>"
                    placeholder="Enter your full name"
                />
            </div>

            <!-- Email (locked) -->
            <div class="field">
                <label for="email">Email Address</label>
                <input
                    type="email"
                    id="email"
                    value="<%= typeof user !== 'undefined' ? user.email : '' %>"
                    disabled
                />
                <p class="lock-note">🔒 Email is linked with your account and cannot be edited.</p>
            </div>

            <!-- Change password -->
            <div class="field" style="margin-bottom:28px;">
                <label>Password</label>
                <a href="/auth/forgot-password" class="password-link">
                    🔑 Change your password via email OTP →
                </a>
            </div>

            <!-- Save -->
            <button class="save-btn" onclick="saveProfile()">Save Changes</button>

            <!-- Delete Profile section -->
            <div class="card" style="border-color: rgba(239,68,68,0.25);">
                <div class="card-label" style="color:#ef4444;">⚠ Danger Zone</div>
                <p style="font-size:0.85rem; color:#9d7fc4; margin-bottom:20px;">Permanently delete your account. This action cannot be undone.</p>

                <button onclick="document.getElementById('delete-profile-modal').style.display='flex'" style="
                    padding: 10px 20px;
                    background: rgba(239,68,68,0.12);
                    border: 1px solid rgba(239,68,68,0.3);
                    border-radius: 10px;
                    color: #fca5a5;
                    font-size: 0.85rem;
                    font-weight: 600;
                    cursor: pointer;
                    transition: background 0.18s;
                " onmouseover="this.style.background='rgba(239,68,68,0.22)'" onmouseout="this.style.background='rgba(239,68,68,0.12)'">
                    🗑 Delete My Account
                </button>
            </div>

            <!-- Delete modal -->
            <div id="delete-profile-modal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.6); backdrop-filter:blur(4px); z-index:999; align-items:center; justify-content:center;">
                <div style="background:#2d0a4e; border:1px solid rgba(239,68,68,0.3); border-radius:20px; padding:32px; width:90%; max-width:400px;">
                    <h3 style="color:#f0e6ff; font-size:1.1rem; margin-bottom:8px;">Delete Account</h3>
                    <p style="color:#9d7fc4; font-size:0.85rem; margin-bottom:20px;">This will permanently delete your account. Enter your password to confirm.</p>
                    <input type="password" id="delete-profile-password" placeholder="Enter your password" style="width:100%; padding:10px 14px; background:rgba(255,255,255,0.07); border:1px solid rgba(168,85,247,0.3); border-radius:10px; color:#f0e6ff; font-size:0.9rem; margin-bottom:8px; outline:none;"/>
                    <p id="delete-profile-error" style="color:#fca5a5; font-size:0.78rem; min-height:18px; margin-bottom:12px;"></p>
                    <div style="display:flex; gap:10px;">
                        <button onclick="document.getElementById('delete-profile-modal').style.display='none'" style="flex:1; padding:10px; background:rgba(255,255,255,0.07); border:1px solid rgba(255,255,255,0.15); border-radius:10px; color:#d4b8f0; cursor:pointer;">Cancel</button>
                        <button onclick="deleteProfile()" style="flex:1; padding:10px; background:linear-gradient(135deg,#ef4444,#dc2626); border:none; border-radius:10px; color:#fff; font-weight:600; cursor:pointer;">Delete Permanently</button>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <script>
        let newImageFile = null;
        let deleteImageFlag = false;

        function previewImage(event) {
            const file = event.target.files[0];
            if (!file) return;
            newImageFile = file;
            deleteImageFlag = false;

            const reader = new FileReader();
            reader.onload = function(e) {
                const preview = document.getElementById('avatar-preview');
                // Replace fallback div with img or update existing img
                if (preview.tagName === 'DIV') {
                    const img = document.createElement('img');
                    img.src = e.target.result;
                    img.className = 'avatar-img';
                    img.id = 'avatar-preview';
                    preview.replaceWith(img);
                } else {
                    preview.src = e.target.result;
                }
            };
            reader.readAsDataURL(file);
        }

        function deleteImage() {
            deleteImageFlag = true;
            newImageFile = null;
            document.getElementById('avatar-input').value = '';

            const preview = document.getElementById('avatar-preview');
            if (preview.tagName === 'IMG') {
                const fallback = document.createElement('div');
                fallback.className = 'avatar-fallback';
                fallback.id = 'avatar-preview';
                fallback.textContent = '<%= typeof user !== "undefined" ? user.name.charAt(0).toUpperCase() : "U" %>';
                preview.replaceWith(fallback);
            }
        }

        async function saveProfile() {
            const name = document.getElementById('name').value.trim();
            const successEl = document.getElementById('alert-success');
            const errorEl = document.getElementById('alert-error');
            const saveBtn = document.querySelector('.save-btn');

            successEl.style.display = 'none';
            errorEl.style.display = 'none';

            if (!name) {
                errorEl.textContent = '⚠ Name cannot be empty.';
                errorEl.style.display = 'block';
                return;
            }

            saveBtn.disabled = true;
            saveBtn.textContent = 'Saving...';

            const formData = new FormData();
            formData.append('name', name);
            if (newImageFile) formData.append('profilePicture', newImageFile);
            if (deleteImageFlag) formData.append('deleteImage', 'true');

            try {
                const res = await fetch('/profile/update', {
                    method: 'POST',
                    body: formData
                });

                const data = await res.json();

                if (!res.ok) {
                    errorEl.textContent = '⚠ ' + (data.message || 'Something went wrong.');
                    errorEl.style.display = 'block';
                } else {
                    successEl.style.display = 'block';
                    newImageFile = null;
                    deleteImageFlag = false;
                }
            } catch (err) {
                errorEl.textContent = '⚠ Network error. Please try again.';
                errorEl.style.display = 'block';
            } finally {
                saveBtn.disabled = false;
                saveBtn.textContent = 'Save Changes';
            }
}

        window.addEventListener('pageshow', function(event) {
            if (event.persisted) window.location.replace('/profile');
        });

        async function deleteProfile() {
            const password = document.getElementById('delete-profile-password').value;
            const errorEl = document.getElementById('delete-profile-error');

            if (!password) {
                errorEl.textContent = 'Please enter your password.';
                return;
            }

            const res = await fetch('/profile/delete', {
                method: 'DELETE',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ password })
            });

            const data = await res.json();

            if (!res.ok) {
                errorEl.textContent = data.message || 'Incorrect password.';
                return;
            }

            window.location.href = '/login';
        }

        window.addEventListener('pageshow', function(event) {
            if (event.persisted) {
                window.location.replace('/login');
            }
        });
    </script>

</body>
</html>