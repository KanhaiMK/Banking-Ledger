<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>System Dashboard</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            background: linear-gradient(135deg, #1a0533 0%, #2d0a4e 50%, #1a0533 100%);
            min-height: 100vh;
        }

        /* ── Navbar ── */
        .navbar {
            background: rgba(255,255,255,0.06);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(255,255,255,0.1);
            padding: 0 32px;
            height: 66px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .navbar-brand {
            font-size: 1.25rem;
            font-weight: 800;
            background: linear-gradient(90deg, #e879f9, #a855f7);
            background-clip: text;
            color: transparent;
            letter-spacing: 0.01em;
        }

        .navbar-right {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .system-badge {
            padding: 4px 12px;
            background: rgba(232,121,249,0.12);
            border: 1px solid rgba(232,121,249,0.3);
            border-radius: 99px;
            font-size: 0.75rem;
            font-weight: 600;
            color: #e879f9;
        }

        .logout-btn {
            display: flex;
            align-items: center;
            gap: 6px;
            padding: 7px 16px;
            background: rgba(255,255,255,0.07);
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 8px;
            font-size: 0.83rem;
            font-weight: 500;
            color: #d4b8f0;
            cursor: pointer;
            transition: background 0.18s, border-color 0.18s, color 0.18s;
        }

        .logout-btn:hover {
            background: rgba(239,68,68,0.15);
            border-color: #ef4444;
            color: #fca5a5;
        }

        /* ── Main ── */
        .main {
            max-width: 780px;
            margin: 48px auto;
            padding: 0 20px;
        }

        /* Welcome section */
        .welcome {
            margin-bottom: 36px;
        }

        .welcome h1 {
            font-size: 1.8rem;
            font-weight: 800;
            color: #f0e6ff;
            margin-bottom: 6px;
        }

        .welcome h1 span {
            background: linear-gradient(90deg, #e879f9, #a855f7);
            background-clip: text;
            color: transparent;
        }

        .welcome p {
            font-size: 0.92rem;
            color: #9d7fc4;
            line-height: 1.6;
        }

        /* Stats row */
        .stats-row {
            display: flex;
            gap: 14px;
            margin-bottom: 32px;
        }

        .stat-card {
            flex: 1;
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(168,85,247,0.25);
            border-radius: 16px;
            padding: 20px;
            backdrop-filter: blur(8px);
            text-align: center;
        }

        .stat-card .stat-number {
            font-size: 2rem;
            font-weight: 800;
            color: #f0e6ff;
        }

        .stat-card .stat-label {
            font-size: 0.78rem;
            color: #9d7fc4;
            margin-top: 4px;
            text-transform: uppercase;
            letter-spacing: 0.08em;
        }

        /* Section */
        .section-label {
            font-size: 0.75rem;
            font-weight: 600;
            color: #a855f7;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            margin-bottom: 16px;
        }

        /* Request card */
        .request-card {
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(168,85,247,0.2);
            border-radius: 16px;
            padding: 20px 24px;
            margin-bottom: 12px;
            backdrop-filter: blur(8px);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
        }

        .request-left {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .request-icon {
            width: 48px;
            height: 48px;
            border-radius: 14px;
            background: linear-gradient(135deg, rgba(232,121,249,0.2), rgba(168,85,247,0.2));
            border: 1px solid rgba(232,121,249,0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.4rem;
            flex-shrink: 0;
        }

        .request-info .request-name {
            font-size: 0.95rem;
            font-weight: 600;
            color: #f0e6ff;
        }

        .request-info .request-meta {
            font-size: 0.78rem;
            color: #9d7fc4;
            margin-top: 3px;
            font-family: monospace;
        }

        .request-amount {
            font-size: 1.2rem;
            font-weight: 800;
            color: #86efac;
            white-space: nowrap;
        }

        .request-right {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        /* Approve / Reject buttons */
        .approve-btn {
            padding: 8px 20px;
            background: linear-gradient(135deg, #22c55e, #16a34a);
            border: none;
            border-radius: 8px;
            color: #fff;
            font-size: 0.83rem;
            font-weight: 600;
            cursor: pointer;
            transition: opacity 0.18s, transform 0.1s;
            box-shadow: 0 4px 12px rgba(34,197,94,0.25);
        }

        .approve-btn:hover { opacity: 0.9; }
        .approve-btn:active { transform: scale(0.97); }

        .reject-btn {
            padding: 8px 20px;
            background: rgba(239,68,68,0.12);
            border: 1px solid rgba(239,68,68,0.3);
            border-radius: 8px;
            color: #fca5a5;
            font-size: 0.83rem;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.18s;
        }

        .reject-btn:hover { background: rgba(239,68,68,0.22); }

        /* Empty / loading state */
        .state-msg {
            text-align: center;
            padding: 48px 0;
            color: #9d7fc4;
            font-size: 0.88rem;
        }

        .state-msg .icon { font-size: 2.5rem; margin-bottom: 10px; }

        /* Toast */
        .toast {
            position: fixed;
            bottom: 28px;
            right: 28px;
            padding: 12px 20px;
            border-radius: 10px;
            font-size: 0.85rem;
            font-weight: 500;
            display: none;
            z-index: 999;
            box-shadow: 0 8px 24px rgba(0,0,0,0.3);
        }

        .toast.success { background: #16a34a; color: #fff; }
        .toast.error   { background: #dc2626; color: #fff; }
    </style>
</head>

<body>

    <!-- ── Navbar ── -->
    <nav class="navbar">
        <div class="navbar-brand">💳 MyBank — System</div>
        <div class="navbar-right">
            <span class="system-badge">⚙ System User</span>
            <form action="/auth/logout" method="POST">
                <button type="submit" class="logout-btn">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/>
                        <polyline points="16 17 21 12 16 7"/>
                        <line x1="21" y1="12" x2="9" y2="12"/>
                    </svg>
                    Logout
                </button>
            </form>
        </div>
    </nav>

    <!-- ── Main ── -->
    <div class="main">

        <!-- Welcome -->
        <div class="welcome">
            <h1>Hello, <span><%= typeof user !== 'undefined' ? user.name : 'System' %></span> 👋</h1>
            <p>Review and process pending fund requests submitted by users. Approve only after verification.</p>
        </div>

        <!-- Stats -->
        <div class="stats-row">
            <div class="stat-card">
                <div class="stat-number" id="stat-pending">—</div>
                <div class="stat-label">Pending Requests</div>
            </div>
            <div class="stat-card">
                <div class="stat-number" id="stat-total">—</div>
                <div class="stat-label">Total Requests Today</div>
            </div>
        </div>

        <!-- Requests list -->
        <div class="section-label">📋 Pending Fund Requests</div>

        <div id="requests-list">
            <div class="state-msg" id="requests-state">
                <div class="icon">⏳</div>
                Loading pending requests...
            </div>
        </div>

    </div>

    <!-- Toast -->
    <div class="toast" id="toast"></div>

    <script>
        async function loadRequests() {
            const stateEl = document.getElementById('requests-state');
            try {
                const res = await fetch('/funds/pending', { method: 'GET' });
                const data = await res.json();

                const requests = data.requests;

                document.getElementById('stat-pending').textContent = requests.length;
                document.getElementById('stat-total').textContent = requests.length;

                if (!requests || requests.length === 0) {
                    stateEl.innerHTML = '<div class="icon">✅</div>No pending requests. All caught up!';
                    return;
                }

                stateEl.remove();

                const list = document.getElementById('requests-list');

                requests.forEach(req => {
                    const card = document.createElement('div');
                    card.className = 'request-card';
                    card.id = `request-${req._id}`;

                    card.innerHTML = `
                        <div class="request-left">
                            <div class="request-icon">💰</div>
                            <div class="request-info">
                                <div class="request-name">${req.requestedBy?.name || 'Unknown User'}</div>
                                <div class="request-meta">${req.requestedBy?.email || ''} · Account: •••• ${String(req.toAccount?.accountNo || req.toAccount?._id).slice(-4)}</div>
                            </div>
                        </div>
                        <div class="request-right">
                            <div class="request-amount">₹${Number(req.amount).toLocaleString('en-IN')}</div>
                            <button class="approve-btn" onclick="approveRequest('${req._id}', '${req.toAccount?._id}', ${req.amount})">Approve</button>
                            <button class="reject-btn" onclick="rejectRequest('${req._id}')">Reject</button>
                        </div>
                    `;

                    list.appendChild(card);
                });

            } catch (err) {
                stateEl.innerHTML = '<div class="icon">⚠️</div>Failed to load requests.';
            }
        }

        async function approveRequest(requestId, toAccount, amount) {
            const idempotencyKey = crypto.randomUUID();
            try {
                const res = await fetch('/transactions/system/initial-funds', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ toAccount, amount, idempotencyKey })
                });

                const data = await res.json();

                // Always update status regardless
                await fetch(`/funds/${requestId}/approve`, { method: 'PATCH' });

                if (!res.ok) {
                    showToast(data.message || 'Failed to approve.', 'error');
                    return;
                }

                document.getElementById(`request-${requestId}`).remove();
                const pendingStat = document.getElementById('stat-pending');
                pendingStat.textContent = Number(pendingStat.textContent) - 1;
                showToast('Fund request approved successfully!', 'success');

                if (document.querySelectorAll('.request-card').length === 0) {
                    document.getElementById('requests-list').innerHTML = '<div class="state-msg"><div class="icon">✅</div>No pending requests. All caught up!</div>';
                }

            } catch (err) {
                showToast('Something went wrong.', 'error');
            }
        }
        async function rejectRequest(requestId) {
            await fetch(`/funds/${requestId}/reject`, { method: 'PATCH' });
            document.getElementById(`request-${requestId}`).remove();

            const pendingStat = document.getElementById('stat-pending');
            pendingStat.textContent = Number(pendingStat.textContent) - 1;

            showToast('Request rejected.', 'error');

            if (document.querySelectorAll('.request-card').length === 0) {
                document.getElementById('requests-list').innerHTML = '<div class="state-msg"><div class="icon">✅</div>No pending requests. All caught up!</div>';
            }
        }

        function showToast(message, type) {
            const toast = document.getElementById('toast');
            toast.textContent = message;
            toast.className = `toast ${type}`;
            toast.style.display = 'block';
            setTimeout(() => toast.style.display = 'none', 3000);
        }

        loadRequests();

        window.addEventListener('pageshow', function(event) {
            if (event.persisted) {
                window.location.replace('/login');
            }
        });
    </script>

</body>
</html>
