<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Account Details</title>
    <link rel="icon" type="image/png" sizes="32x32" href="/images/uploads/mk-favicon.png">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            background: linear-gradient(135deg, #1a0533 0%, #2d0a4e 50%, #1a0533 100%);
            min-height: 100vh;
        }

        /* ── Navbar ── */
        .navbar {
            background: rgba(255,255,255,0.06);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(255,255,255,0.1);
            padding: 0 32px;
            height: 66px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .navbar-brand {
            font-size: 1.25rem;
            font-weight: 800;
            background: linear-gradient(90deg, #e879f9, #a855f7);
            background-clip: text;
            color: transparent;
            letter-spacing: 0.01em;
        }

        .back-btn {
            display: flex;
            align-items: center;
            gap: 6px;
            padding: 7px 16px;
            background: rgba(255,255,255,0.07);
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 8px;
            font-size: 0.83rem;
            font-weight: 500;
            color: #d4b8f0;
            cursor: pointer;
            text-decoration: none;
            transition: background 0.18s, border-color 0.18s;
        }

        .back-btn:hover {
            background: rgba(168,85,247,0.15);
            border-color: #a855f7;
        }

        /* ── Main ── */
        .main {
            max-width: 680px;
            margin: 48px auto;
            padding: 0 20px;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        /* Account ID header */
        .account-header {
            text-align: center;
            margin-bottom: 8px;
        }

        .account-header p {
            font-size: 0.8rem;
            color: #9d7fc4;
            margin-bottom: 6px;
            text-transform: uppercase;
            letter-spacing: 0.08em;
        }

        .account-header h1 {
            font-size: 1.1rem;
            font-weight: 700;
            color: #f0e6ff;
            font-family: monospace;
            letter-spacing: 0.05em;
        }

        /* ── Card base ── */
        .card {
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(168,85,247,0.25);
            border-radius: 20px;
            padding: 28px 28px;
            backdrop-filter: blur(8px);
        }

        .card-label {
            font-size: 0.75rem;
            font-weight: 600;
            color: #a855f7;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            margin-bottom: 18px;
        }

        /* ── Balance card ── */
        .balance-card {
            background: linear-gradient(135deg, rgba(232,121,249,0.12), rgba(168,85,247,0.12));
            border: 1px solid rgba(232,121,249,0.3);
        }

        .balance-display {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .balance-left h2 {
            font-size: 2.4rem;
            font-weight: 800;
            color: #f0e6ff;
            letter-spacing: -0.02em;
        }

        .balance-left h2 span {
            font-size: 1.2rem;
            font-weight: 500;
            color: #c4b5fd;
            margin-right: 4px;
        }

        .balance-left p {
            font-size: 0.8rem;
            color: #9d7fc4;
            margin-top: 6px;
        }

        .balance-icon {
            width: 64px;
            height: 64px;
            border-radius: 18px;
            background: linear-gradient(135deg, rgba(232,121,249,0.25), rgba(168,85,247,0.25));
            border: 1px solid rgba(232,121,249,0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
        }

        .refresh-btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            margin-top: 20px;
            padding: 8px 18px;
            background: rgba(168,85,247,0.15);
            border: 1px solid rgba(168,85,247,0.3);
            border-radius: 8px;
            font-size: 0.82rem;
            font-weight: 500;
            color: #c4b5fd;
            cursor: pointer;
            transition: background 0.18s, border-color 0.18s;
        }

        .refresh-btn:hover {
            background: rgba(168,85,247,0.25);
            border-color: #a855f7;
        }

        .balance-loading {
            font-size: 0.88rem;
            color: #9d7fc4;
            font-style: italic;
        }

        .balance-error {
            font-size: 0.85rem;
            color: #fca5a5;
        }

        /* ── Status badge ── */
        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 4px 12px;
            border-radius: 99px;
            font-size: 0.75rem;
            font-weight: 600;
            margin-top: 10px;
        }

        .status-ACTIVE  { background: rgba(134,239,172,0.12); color: #86efac; border: 1px solid rgba(134,239,172,0.25); }
        .status-FROZEN  { background: rgba(252,211,77,0.12);  color: #fcd34d; border: 1px solid rgba(252,211,77,0.25); }
        .status-CLOSED  { background: rgba(252,165,165,0.12); color: #fca5a5; border: 1px solid rgba(252,165,165,0.25); }

        /* ── Transaction card ── */
        .transaction-card {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .transaction-card p {
            font-size: 0.88rem;
            color: #9d7fc4;
            line-height: 1.6;
        }

        .create-txn-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 13px 28px;
            background: linear-gradient(135deg, #e879f9, #a855f7);
            color: #fff;
            border: none;
            border-radius: 12px;
            font-size: 0.95rem;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            transition: opacity 0.18s, transform 0.15s, box-shadow 0.18s;
            box-shadow: 0 4px 20px rgba(168,85,247,0.35);
            align-self: flex-start;
        }

        .create-txn-btn:hover {
            opacity: 0.9;
            transform: translateY(-1px);
            box-shadow: 0 6px 28px rgba(168,85,247,0.45);
        }

        .create-txn-btn:active { transform: scale(0.98); }

        .history-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 14px 0;
            border-bottom: 1px solid rgba(168,85,247,0.1);
        }

        .history-item:last-child { border-bottom: none; }

        .history-icon {
            width: 38px;
            height: 38px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            flex-shrink: 0;
            margin-right: 12px;
        }

        .history-info .history-title {
            font-size: 0.88rem;
            font-weight: 600;
            color: #f0e6ff;
        }

        .history-info .history-date {
            font-size: 0.75rem;
            color: #9d7fc4;
            margin-top: 2px;
        }

        .history-left { display: flex; align-items: center; }

        .history-right { text-align: right; }

        .history-amount {
            font-size: 0.95rem;
            font-weight: 700;
        }

        .history-status {
            font-size: 0.72rem;
            font-weight: 600;
            margin-top: 2px;
}

    </style>
</head>

<body>

    <!-- ── Navbar ── -->
    <nav class="navbar">
        <h2 style="
                font-size: 1.4rem;
                font-weight: 900;
                letter-spacing: 0.02em;
                background: linear-gradient(135deg, #e879f9 0%, #a855f7 50%, #7c3aed 100%);
                background-clip: text;
                color: transparent;
                text-shadow: 0 0 30px rgba(168,85,247,0.4);
                display: flex;
                align-items: center;
                gap: 8px;
            ">
                <img src="/images/uploads/mk-favicon.png" style="width: 36px; height: 36px; border-radius: 8px; object-fit: cover;" alt="MK Logo">MK_Bank
        </h2>
        <a href="/accounts" class="back-btn">
            ← Back to Accounts
        </a>
        <button onclick="document.getElementById('delete-modal').style.display='flex'" style="
            padding: 7px 16px;
            background: rgba(239,68,68,0.12);
            border: 1px solid rgba(239,68,68,0.3);
            border-radius: 8px;
            font-size: 0.83rem;
            font-weight: 500;
            color: #fca5a5;
            cursor: pointer;
    ">🗑 Delete Account</button>
    </nav>

    <!-- ── Main ── -->
    <div class="main">

        <!-- Account ID -->
        <div class="account-header">
            <p>Account Number</p>
            <h1><%= account.accountNo %></h1>
            <div class="status-badge status-<%= account.status %>">
                ● <%= account.status %>
            </div>
        </div>

        <!-- Balance section -->
        <div class="card balance-card">
            <div class="card-label">💰 Balance</div>
            <div class="balance-display">
                <div class="balance-left">
                    <h2 id="balance-amount">
                        <span class="balance-loading">Fetching balance...</span>
                    </h2>
                    <p id="balance-sub"></p>
                </div>
                <div class="balance-icon">💳</div>
            </div>
            <button class="refresh-btn" onclick="fetchBalance()">
                ↻ Refresh Balance
            </button>
        </div>

        <!-- Transaction section -->
        <div class="card transaction-card">
            <div class="card-label">🔁 Transactions</div>
            <p>Send money, request money, or transfer funds between accounts.</p>

            <div style="display:flex; gap:12px; flex-wrap:wrap;">
                <button onclick="toggleAddMoneyForm()" class="create-txn-btn" style="background: linear-gradient(135deg, #22c55e, #16a34a); box-shadow: 0 4px 20px rgba(34,197,94,0.35);">
                    + Add Money
                    <p style="color: rgb(57, 79, 95);">(Request from bank system)</p>
                </button>
                <button onclick="toggleTransactionForm()" class="create-txn-btn">
                    + Create New Transaction
                </button>
            </div>

            <!-- Add Money Form -->
            <div id="add-money-form" style="display:none; margin-top:20px; background:rgba(34,197,94,0.06); border:1px solid rgba(34,197,94,0.2); border-radius:16px; padding:24px;">
                <p style="color:#86efac; font-size:0.8rem; font-weight:600; text-transform:uppercase; letter-spacing:0.1em; margin-bottom:16px;">💰 Request Funds</p>
                <label style="font-size:0.82rem; color:#9d7fc4; margin-bottom:6px; display:block;">Amount</label>
                <input type="number" id="fund-amount" placeholder="Enter amount" min="1" style="width:100%; padding:10px 14px; background:rgba(255,255,255,0.07); border:1px solid rgba(168,85,247,0.3); border-radius:10px; color:#f0e6ff; font-size:0.9rem; outline:none; margin-bottom:8px;"/>
                <p id="fund-error" style="color:#fca5a5; font-size:0.78rem; min-height:18px; margin-bottom:12px;"></p>
                <div style="display:flex; gap:10px;">
                    <button onclick="toggleAddMoneyForm()" style="flex:1; padding:10px; background:rgba(255,255,255,0.07); border:1px solid rgba(255,255,255,0.15); border-radius:10px; color:#d4b8f0; cursor:pointer;">Cancel</button>
                    <button onclick="submitFundRequest()" style="flex:1; padding:10px; background:linear-gradient(135deg,#22c55e,#16a34a); border:none; border-radius:10px; color:#fff; font-weight:600; cursor:pointer;">Submit Request</button>
                </div>
                <p id="fund-success" style="color:#86efac; font-size:0.82rem; margin-top:12px; display:none;">✓ Request submitted! Awaiting system approval.</p>
            </div>

            <!-- Create Transaction Form -->
            <div id="transaction-form" style="display:none; margin-top:20px; background:rgba(168,85,247,0.06); border:1px solid rgba(168,85,247,0.2); border-radius:16px; padding:24px;">
                <p style="color:#c4b5fd; font-size:0.8rem; font-weight:600; text-transform:uppercase; letter-spacing:0.1em; margin-bottom:16px;">🔁 New Transaction</p>

                <label style="font-size:0.82rem; color:#9d7fc4; margin-bottom:6px; display:block;">Recipient Account Number</label>
                <input type="text" id="txn-to-account" placeholder="Enter 11 digit account number" maxlength="11" style="width:100%; padding:10px 14px; background:rgba(255,255,255,0.07); border:1px solid rgba(168,85,247,0.3); border-radius:10px; color:#f0e6ff; font-size:0.9rem; outline:none; margin-bottom:16px;"/>

                <label style="font-size:0.82rem; color:#9d7fc4; margin-bottom:6px; display:block;">Amount</label>
                <input type="number" id="txn-amount" placeholder="Enter amount" min="1" style="width:100%; padding:10px 14px; background:rgba(255,255,255,0.07); border:1px solid rgba(168,85,247,0.3); border-radius:10px; color:#f0e6ff; font-size:0.9rem; outline:none; margin-bottom:8px;"/>

                <p id="txn-error" style="color:#fca5a5; font-size:0.78rem; min-height:18px; margin-bottom:12px;"></p>

                <div style="display:flex; gap:10px;">
                    <button onclick="toggleTransactionForm()" style="flex:1; padding:10px; background:rgba(255,255,255,0.07); border:1px solid rgba(255,255,255,0.15); border-radius:10px; color:#d4b8f0; cursor:pointer;">Cancel</button>
                    <button onclick="submitTransaction()" style="flex:1; padding:10px; background:linear-gradient(135deg,#e879f9,#a855f7); border:none; border-radius:10px; color:#fff; font-weight:600; cursor:pointer;">Send Money</button>
                </div>

                <p id="txn-success" style="color:#86efac; font-size:0.82rem; margin-top:12px; display:none;">✓ Transaction completed successfully!</p>
                <p id="txn-pending" style="color:#fcd34d; font-size:0.82rem; margin-top:12px; display:none;">⏳ Transaction is processing, please wait...</p>
            </div>
        </div>
        
        <!-- Transaction History -->
        <div class="card" style="margin-top:20px;">
            <div class="card-label">📜 Transaction History</div>
            <div id="txn-history-list">
                <div class="state-msg" id="txn-history-state">
                    <div class="icon">⏳</div>
                    Loading transactions...
                </div>
            </div>
        </div>

        <!-- Fund Request History -->
        <div class="card" style="margin-top:20px;">
            <div class="card-label">💰 Fund Request History</div>
            <div id="fund-history-list">
                <div class="state-msg" id="fund-history-state">
                    <div class="icon">⏳</div>
                    Loading requests...
                </div>
            </div>
        </div>

        <div id="delete-modal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.6); backdrop-filter:blur(4px); z-index:999; align-items:center; justify-content:center;">
            <div style="background:#2d0a4e; border:1px solid rgba(239,68,68,0.3); border-radius:20px; padding:32px; width:90%; max-width:400px;">
                <h3 style="color:#f0e6ff; font-size:1.1rem; margin-bottom:8px;">Delete Account</h3>
                <p style="color:#9d7fc4; font-size:0.85rem; margin-bottom:20px;">This is permanent. Enter your password to confirm.</p>
                <input type="password" id="confirm-password" placeholder="Enter your password" style="width:100%; padding:10px 14px; background:rgba(255,255,255,0.07); border:1px solid rgba(168,85,247,0.3); border-radius:10px; color:#f0e6ff; font-size:0.9rem; margin-bottom:8px; outline:none;"/>
                <p id="delete-error" style="color:#fca5a5; font-size:0.78rem; min-height:18px; margin-bottom:12px;"></p>
                <div style="display:flex; gap:10px;">
                    <button onclick="document.getElementById('delete-modal').style.display='none'" style="flex:1; padding:10px; background:rgba(255,255,255,0.07); border:1px solid rgba(255,255,255,0.15); border-radius:10px; color:#d4b8f0; cursor:pointer;">Cancel</button>
                    <button onclick="deleteAccount()" style="flex:1; padding:10px; background:linear-gradient(135deg,#ef4444,#dc2626); border:none; border-radius:10px; color:#fff; font-weight:600; cursor:pointer;">Delete Permanently</button>
                </div>
            </div>
        </div>

    </div>


    <script>
        function toggleAddMoneyForm() {
            const form = document.getElementById('add-money-form');
            form.style.display = form.style.display === 'none' ? 'block' : 'none';
            document.getElementById('fund-error').textContent = '';
            document.getElementById('fund-amount').value = '';
            document.getElementById('fund-success').style.display = 'none';
        }
        
        async function submitFundRequest() {
            const amount = document.getElementById('fund-amount').value;
            const errorEl = document.getElementById('fund-error');
            const successEl = document.getElementById('fund-success');
            errorEl.textContent = '';
            if (!amount || amount <= 0) {
                errorEl.textContent = 'Please enter a valid amount.';
                return;
            }
            const res = await fetch(`/funds/<%= account._id %>/request-funds`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ amount: Number(amount) })
            });
            const data = await res.json();
            if (!res.ok) {
                errorEl.textContent = data.message || 'Something went wrong.';
                return;
            }
            successEl.style.display = 'block';
            document.getElementById('fund-amount').value = '';
        }

        async function submitTransaction() {
            const toAccountNo = document.getElementById('txn-to-account').value.trim();
            const amount = document.getElementById('txn-amount').value;
            const errorEl = document.getElementById('txn-error');
            const successEl = document.getElementById('txn-success');
            const pendingEl = document.getElementById('txn-pending');

            errorEl.textContent = '';
            successEl.style.display = 'none';
            pendingEl.style.display = 'none';

            if (!toAccountNo || toAccountNo.length !== 11) {
                errorEl.textContent = 'Please enter a valid 11 digit account number.';
                return;
            }

            if (!amount || amount <= 0) {
                errorEl.textContent = 'Please enter a valid amount.';
                return;
            }

            const idempotencyKey = crypto.randomUUID();
            pendingEl.style.display = 'block';

            const res = await fetch('/transactions', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    fromAccount: '<%= account.accountNo %>',
                    toAccount: toAccountNo,
                    amount: Number(amount),
                    idempotencyKey
                })
            });

            pendingEl.style.display = 'none';
            const data = await res.json();

            if (!res.ok) {
                errorEl.textContent = data.message || 'Transaction failed.';
                return;
            }

            successEl.style.display = 'block';
            document.getElementById('txn-to-account').value = '';
            document.getElementById('txn-amount').value = '';
            fetchBalance();
        }

        function toggleTransactionForm() {
            const form = document.getElementById('transaction-form');
            if (form.style.display === 'none') {
                // Open form
                form.style.display = 'block';
            } else {
                // Clear inputs
                document.getElementById('txn-to-account').value = '';
                document.getElementById('txn-amount').value = '';
                // Clear messages
                document.getElementById('txn-error').textContent = '';
                document.getElementById('txn-success').style.display = 'none';
                document.getElementById('txn-pending').style.display = 'none';
                // Hide form
                form.style.display = 'none';
            }
        }

        const accountId = '<%= account._id %>';

        async function fetchBalance() {
            const amountEl = document.getElementById('balance-amount');
            const subEl = document.getElementById('balance-sub');

            amountEl.innerHTML = '<span class="balance-loading">Fetching balance...</span>';
            subEl.textContent = '';

            try {
                const res = await fetch(`/accounts/balance/${accountId}`, { method: 'GET' });
                const data = await res.json();

                if (!res.ok) {
                    amountEl.innerHTML = '<span class="balance-error">Failed to load balance</span>';
                    return;
                }

                const balance = data.balance ?? data.amount ?? 0;
                const currency = data.currency || '₹';

                amountEl.innerHTML = `<span>${currency}</span>${Number(balance).toLocaleString('en-IN', { minimumFractionDigits: 2 })}`;
                subEl.textContent = 'Available balance';

            } catch (err) {
                amountEl.innerHTML = '<span class="balance-error">⚠ Could not fetch balance</span>';
            }
        }

        // Auto fetch on load
        fetchBalance();
        async function deleteAccount() {
        const password = document.getElementById('confirm-password').value;
        const errorEl = document.getElementById('delete-error');

        if (!password) {
            errorEl.textContent = 'Please enter your password.';
            return;
        }

        const res = await fetch(`/accounts/<%= account._id %>/delete`, {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ password })
        });

        const data = await res.json();

        if (!res.ok) {
            errorEl.textContent = data.message || 'Incorrect password.';
            return;
        }
        window.location.href = '/accounts';
    }

        async function loadTransactionHistory() {
            const stateEl = document.getElementById('txn-history-state');
            try {
                const res = await fetch(`/transactions/${accountId}`, { method: 'GET' });
                const data = await res.json();
                const transactions = data.transactions;

                if (!transactions || transactions.length === 0) {
                    stateEl.innerHTML = '<div class="icon">📭</div>No transactions yet.';
                    return;
                }

                stateEl.remove();
                const list = document.getElementById('txn-history-list');

                transactions.forEach(txn => {
                    const isDebit = String(txn.fromAccount) === accountId;
                    const color = isDebit ? '#fca5a5' : '#86efac';
                    const sign = isDebit ? '−' : '+';
                    const icon = isDebit ? '↑' : '↓';
                    const iconBg = isDebit ? 'rgba(239,68,68,0.15)' : 'rgba(34,197,94,0.15)';

                    const statusColor = txn.status === 'COMPLETED' ? '#86efac' :
                                        txn.status === 'PENDING'   ? '#fcd34d' :
                                        txn.status === 'FAILED'    ? '#fca5a5' : '#9d7fc4';

                    const date = new Date(txn.createdAt).toLocaleDateString('en-IN', {
                        day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit'
                    });

                    const item = document.createElement('div');
                    item.className = 'history-item';
                    item.innerHTML = `
                        <div class="history-left">
                            <div class="history-icon" style="background:${iconBg};">${icon}</div>
                            <div class="history-info">
                                <div class="history-title">${isDebit ? 'Sent' : 'Received'}</div>
                                <div class="history-date">${date}</div>
                            </div>
                        </div>
                        <div class="history-right">
                            <div class="history-amount" style="color:${color};">${sign} ₹${Number(txn.amount).toLocaleString('en-IN')}</div>
                            <div class="history-status" style="color:${statusColor};">● ${txn.status}</div>
                        </div>
                    `;
                    list.appendChild(item);
                });

            } catch (err) {
                stateEl.innerHTML = '<div class="icon">⚠️</div>Failed to load transactions.';
            }
        }

        async function loadFundRequestHistory() {
            const stateEl = document.getElementById('fund-history-state');
            try {
                const res = await fetch(`/funds/${accountId}/history`, { method: 'GET' });
                const data = await res.json();
                const requests = data.requests;

                if (!requests || requests.length === 0) {
                    stateEl.innerHTML = '<div class="icon">📭</div>No fund requests yet.';
                    return;
                }

                stateEl.remove();
                const list = document.getElementById('fund-history-list');

                requests.forEach(req => {
                    const statusColor = req.status === 'APPROVED' ? '#86efac' :
                                        req.status === 'PENDING'  ? '#fcd34d' : '#fca5a5';

                    const date = new Date(req.createdAt).toLocaleDateString('en-IN', {
                        day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit'
                    });

                    const item = document.createElement('div');
                    item.className = 'history-item';
                    item.innerHTML = `
                        <div class="history-left">
                            <div class="history-icon" style="background:rgba(34,197,94,0.15);">💰</div>
                            <div class="history-info">
                                <div class="history-title">Fund Request</div>
                                <div class="history-date">${date}</div>
                            </div>
                        </div>
                        <div class="history-right">
                            <div class="history-amount" style="color:#86efac;">+ ₹${Number(req.amount).toLocaleString('en-IN')}</div>
                            <div class="history-status" style="color:${statusColor};">● ${req.status}</div>
                        </div>
                    `;
                    list.appendChild(item);
                });

            } catch (err) {
                stateEl.innerHTML = '<div class="icon">⚠️</div>Failed to load requests.';
            }
        }

        // Call both on page load
        loadTransactionHistory();
        loadFundRequestHistory();

        window.addEventListener('pageshow', function(event) {
            if (event.persisted) {
                window.location.replace('/login');
            }
        });
    </script>

</body>
</html>