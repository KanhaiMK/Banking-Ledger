<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reset Password</title>
    <link rel="icon" type="image/png" sizes="32x32" href="/images/uploads/mk-favicon.png">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            background: linear-gradient(135deg, #1a0533 0%, #2d0a4e 50%, #1a0533 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .card {
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(168,85,247,0.25);
            border-radius: 20px;
            padding: 40px 36px;
            width: 90%;
            max-width: 440px;
            backdrop-filter: blur(12px);
        }

        .icon-wrap {
            width: 64px;
            height: 64px;
            border-radius: 18px;
            background: linear-gradient(135deg, rgba(232,121,249,0.2), rgba(168,85,247,0.2));
            border: 1px solid rgba(232,121,249,0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            margin-bottom: 20px;
        }

        h2 {
            font-size: 1.4rem;
            font-weight: 700;
            color: #f0e6ff;
            margin-bottom: 8px;
        }

        p.subtitle {
            font-size: 0.85rem;
            color: #9d7fc4;
            margin-bottom: 24px;
            line-height: 1.6;
        }

        .alert {
            padding: 10px 14px;
            border-radius: 8px;
            font-size: 0.83rem;
            margin-bottom: 16px;
        }

        .alert-error { background: rgba(239,68,68,0.12); color: #fca5a5; border: 1px solid rgba(239,68,68,0.25); }

        .field { margin-bottom: 16px; }

        .field label {
            display: block;
            font-size: 0.8rem;
            color: #9d7fc4;
            font-weight: 500;
            margin-bottom: 6px;
        }

        .input-wrap { position: relative; }

        .input-wrap input {
            width: 100%;
            padding: 11px 42px 11px 14px;
            background: rgba(255,255,255,0.07);
            border: 1px solid rgba(168,85,247,0.3);
            border-radius: 10px;
            color: #f0e6ff;
            font-size: 0.9rem;
            outline: none;
            transition: border-color 0.18s, box-shadow 0.18s;
        }

        .input-wrap input:focus {
            border-color: #a855f7;
            box-shadow: 0 0 0 3px rgba(168,85,247,0.15);
        }

        .input-wrap input::placeholder { color: #6b4f8a; }

        .toggle-pw {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            cursor: pointer;
            color: #6b4f8a;
            font-size: 1rem;
            padding: 0;
        }

        .field-note {
            font-size: 0.74rem;
            color: #fca5a5;
            margin-top: 4px;
            min-height: 16px;
        }

        .submit-btn {
            width: 100%;
            padding: 12px;
            background: linear-gradient(135deg, #e879f9, #a855f7);
            border: none;
            border-radius: 10px;
            color: #fff;
            font-size: 0.95rem;
            font-weight: 600;
            cursor: pointer;
            transition: opacity 0.18s, transform 0.1s;
            box-shadow: 0 4px 20px rgba(168,85,247,0.35);
            margin-top: 8px;
        }

        .submit-btn:hover { opacity: 0.9; }
        .submit-btn:active { transform: scale(0.98); }
        .submit-btn:disabled { opacity: 0.5; cursor: not-allowed; }
    </style>
</head>
<body>

    <div class="card">
        <div class="icon-wrap">🔑</div>
        <h2>Reset Password</h2>
        <p class="subtitle">Enter your new password below.</p>

        <% if (typeof query !== 'undefined' && query.error === 'password_mismatch') { %>
            <div class="alert alert-error">⚠ Passwords do not match.</div>
        <% } %>
        <% if (typeof query !== 'undefined' && query.error === 'password_short') { %>
            <div class="alert alert-error">⚠ Password must be atleast 6 characters.</div>
        <% } %>

        <form action="/auth/reset-password" method="POST">
            <input type="hidden" name="email" value="<%= typeof query !== 'undefined' ? query.email : '' %>" />

            <div class="field">
                <label for="password">New Password</label>
                <div class="input-wrap">
                    <input type="password" id="password" name="password" placeholder="Enter new password" oninput="validatePasswords()" />
                    <button type="button" class="toggle-pw" onclick="togglePw('password')">👁</button>
                </div>
                <p class="field-note" id="pw-length-note"></p>
            </div>

            <div class="field">
                <label for="confirmPassword">Confirm Password</label>
                <div class="input-wrap">
                    <input type="password" id="confirmPassword" name="confirmPassword" placeholder="Re-enter new password" oninput="validatePasswords()" />
                    <button type="button" class="toggle-pw" onclick="togglePw('confirmPassword')">👁</button>
                </div>
                <p class="field-note" id="pw-match-note"></p>
            </div>

            <button type="submit" class="submit-btn" id="submit-btn" disabled>Reset Password</button>
        </form>
    </div>

    <script>
        function togglePw(id) {
            const input = document.getElementById(id);
            input.type = input.type === 'password' ? 'text' : 'password';
        }

        function validatePasswords() {
            const pw = document.getElementById('password').value;
            const confirm = document.getElementById('confirmPassword').value;
            const lengthNote = document.getElementById('pw-length-note');
            const matchNote = document.getElementById('pw-match-note');
            const submitBtn = document.getElementById('submit-btn');

            // Length check
            if (pw.length > 0 && pw.length < 6) {
                lengthNote.textContent = '⚠ Password must be atleast 6 characters';
                document.getElementById('password').style.borderColor = '#ef4444';
            } else if (pw.length >= 6) {
                lengthNote.textContent = '';
                document.getElementById('password').style.borderColor = '#22c55e';
            } else {
                lengthNote.textContent = '';
                document.getElementById('password').style.borderColor = 'rgba(168,85,247,0.3)';
            }

            // Match check
            if (confirm.length > 0 && pw !== confirm) {
                matchNote.textContent = '⚠ Passwords do not match';
                document.getElementById('confirmPassword').style.borderColor = '#ef4444';
                submitBtn.disabled = true;
            } else if (confirm.length > 0 && pw === confirm && pw.length >= 6) {
                matchNote.textContent = '';
                document.getElementById('confirmPassword').style.borderColor = '#22c55e';
                submitBtn.disabled = false;
            } else {
                matchNote.textContent = '';
                document.getElementById('confirmPassword').style.borderColor = 'rgba(168,85,247,0.3)';
                submitBtn.disabled = true;
            }
        }

        window.addEventListener('pageshow', function(event) {
            if (event.persisted) {
                window.location.replace('/login');
            }
        });
    </script>

</body>
</html>
