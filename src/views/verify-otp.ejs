<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Verify OTP</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            background: linear-gradient(135deg, #1a0533 0%, #2d0a4e 50%, #1a0533 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .card {
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(168,85,247,0.25);
            border-radius: 20px;
            padding: 40px 36px;
            width: 90%;
            max-width: 440px;
            backdrop-filter: blur(12px);
        }

        .icon-wrap {
            width: 64px;
            height: 64px;
            border-radius: 18px;
            background: linear-gradient(135deg, rgba(232,121,249,0.2), rgba(168,85,247,0.2));
            border: 1px solid rgba(232,121,249,0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            margin-bottom: 20px;
        }

        h2 {
            font-size: 1.4rem;
            font-weight: 700;
            color: #f0e6ff;
            margin-bottom: 8px;
        }

        p.subtitle {
            font-size: 0.85rem;
            color: #9d7fc4;
            margin-bottom: 24px;
            line-height: 1.6;
        }

        .email-badge {
            display: inline-block;
            background: rgba(168,85,247,0.15);
            color: #c4b5fd;
            font-size: 0.82rem;
            font-weight: 600;
            padding: 4px 12px;
            border-radius: 99px;
            margin-bottom: 20px;
            border: 1px solid rgba(168,85,247,0.25);
        }

        .alert {
            padding: 10px 14px;
            border-radius: 8px;
            font-size: 0.83rem;
            margin-bottom: 16px;
        }

        .alert-error { background: rgba(239,68,68,0.12); color: #fca5a5; border: 1px solid rgba(239,68,68,0.25); }

        /* OTP inputs */
        .otp-row {
            display: flex;
            gap: 12px;
            justify-content: center;
            margin-bottom: 24px;
        }

        .otp-input {
            width: 64px;
            height: 64px;
            text-align: center;
            font-size: 1.6rem;
            font-weight: 700;
            background: rgba(255,255,255,0.07);
            border: 1.5px solid rgba(168,85,247,0.3);
            border-radius: 12px;
            color: #f0e6ff;
            outline: none;
            transition: border-color 0.18s, box-shadow 0.18s;
        }

        .otp-input:focus {
            border-color: #e879f9;
            box-shadow: 0 0 0 3px rgba(232,121,249,0.15);
        }

        .submit-btn {
            width: 100%;
            padding: 12px;
            background: linear-gradient(135deg, #e879f9, #a855f7);
            border: none;
            border-radius: 10px;
            color: #fff;
            font-size: 0.95rem;
            font-weight: 600;
            cursor: pointer;
            transition: opacity 0.18s, transform 0.1s;
            box-shadow: 0 4px 20px rgba(168,85,247,0.35);
            margin-bottom: 16px;
        }

        .submit-btn:hover { opacity: 0.9; }
        .submit-btn:active { transform: scale(0.98); }

        /* Resend */
        .resend-row {
            text-align: center;
            font-size: 0.82rem;
            color: #9d7fc4;
        }

        .resend-btn {
            background: none;
            border: none;
            color: #e879f9;
            font-size: 0.82rem;
            font-weight: 600;
            cursor: pointer;
            padding: 0;
        }

        .resend-btn:disabled {
            color: #6b4f8a;
            cursor: not-allowed;
        }

        .back-link {
            display: block;
            text-align: center;
            margin-top: 16px;
            font-size: 0.82rem;
            color: #9d7fc4;
            text-decoration: none;
        }

        .back-link:hover { color: #e879f9; }
    </style>
</head>
<body>

    <div class="card">
        <div class="icon-wrap">📩</div>
        <h2>Enter OTP</h2>
        <p class="subtitle">We've sent a 4-digit OTP to your email address.</p>

        <div class="email-badge">✉ <%= typeof query !== 'undefined' ? query.email : '' %></div>

        <% if (typeof query !== 'undefined' && query.error === 'invalid_otp') { %>
            <div class="alert alert-error">⚠ Invalid OTP. Please try again.</div>
        <% } %>
        <% if (typeof query !== 'undefined' && query.error === 'otp_expired') { %>
            <div class="alert alert-error">⚠ OTP has expired. Please request a new one.</div>
        <% } %>

        <form action="/auth/verify-otp" method="POST" id="otp-form">
            <input type="hidden" name="email" value="<%= typeof query !== 'undefined' ? query.email : '' %>" />
            <input type="hidden" name="otp" id="otp-hidden" />

            <div class="otp-row">
                <input type="text" maxlength="1" class="otp-input" id="otp-0" />
                <input type="text" maxlength="1" class="otp-input" id="otp-1" />
                <input type="text" maxlength="1" class="otp-input" id="otp-2" />
                <input type="text" maxlength="1" class="otp-input" id="otp-3" />
            </div>

            <button type="submit" class="submit-btn" onclick="return combineOTP()">Verify OTP</button>
        </form>

        <div class="resend-row">
            Didn't receive it?
            <button class="resend-btn" id="resend-btn" disabled onclick="resendOTP()">
                Resend in <span id="countdown">60</span>s
            </button>
        </div>

        <a href="/auth/forgot-password" class="back-link">← Change email</a>
    </div>

    <script>
        // Auto focus next OTP input
        document.querySelectorAll('.otp-input').forEach((input, index) => {
            input.addEventListener('input', () => {
                if (input.value.length === 1 && index < 3) {
                    document.getElementById(`otp-${index + 1}`).focus();
                }
            });
            input.addEventListener('keydown', (e) => {
                if (e.key === 'Backspace' && input.value === '' && index > 0) {
                    document.getElementById(`otp-${index - 1}`).focus();
                }
            });
        });

        function combineOTP() {
            const otp = Array.from({length: 4}, (_, i) => document.getElementById(`otp-${i}`).value).join('');
            if (otp.length !== 4) {
                alert('Please enter all 4 digits.');
                return false;
            }
            document.getElementById('otp-hidden').value = otp;
            return true;
        }

        // Countdown for resend
        let seconds = 60;
        const countdownEl = document.getElementById('countdown');
        const resendBtn = document.getElementById('resend-btn');

        const timer = setInterval(() => {
            seconds--;
            countdownEl.textContent = seconds;
            if (seconds <= 0) {
                clearInterval(timer);
                resendBtn.disabled = false;
                resendBtn.textContent = 'Resend OTP';
            }
        }, 1000);

        async function resendOTP() {
            const email = '<%= typeof query !== "undefined" ? query.email : "" %>';
            resendBtn.disabled = true;
            resendBtn.textContent = 'Sending...';

            const res = await fetch('/auth/resend-otp', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email })
            });

            if (res.ok) {
                resendBtn.textContent = 'Resend in 60s';
                seconds = 60;
                const newTimer = setInterval(() => {
                    seconds--;
                    resendBtn.textContent = `Resend in ${seconds}s`;
                    if (seconds <= 0) {
                        clearInterval(newTimer);
                        resendBtn.disabled = false;
                        resendBtn.textContent = 'Resend OTP';
                    }
                }, 1000);
            } else {
                resendBtn.disabled = false;
                resendBtn.textContent = 'Resend OTP';
            }
        }

        window.addEventListener('pageshow', function(event) {
            if (event.persisted) {
                window.location.replace('/login');
            }
        });
    </script>

</body>
</html>
