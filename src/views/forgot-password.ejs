<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Forgot Password</title>
    <link rel="icon" type="image/png" sizes="32x32" href="/images/uploads/mk-favicon.png">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            background: linear-gradient(135deg, #1a0533 0%, #2d0a4e 50%, #1a0533 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .card {
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(168,85,247,0.25);
            border-radius: 20px;
            padding: 40px 36px;
            width: 90%;
            max-width: 440px;
            backdrop-filter: blur(12px);
        }

        .icon-wrap {
            width: 64px;
            height: 64px;
            border-radius: 18px;
            background: linear-gradient(135deg, rgba(232,121,249,0.2), rgba(168,85,247,0.2));
            border: 1px solid rgba(232,121,249,0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            margin-bottom: 20px;
        }

        h2 {
            font-size: 1.4rem;
            font-weight: 700;
            color: #f0e6ff;
            margin-bottom: 8px;
        }

        p.subtitle {
            font-size: 0.85rem;
            color: #9d7fc4;
            margin-bottom: 24px;
            line-height: 1.6;
        }

        .alert {
            padding: 10px 14px;
            border-radius: 8px;
            font-size: 0.83rem;
            margin-bottom: 16px;
        }

        .alert-error   { background: rgba(239,68,68,0.12); color: #fca5a5; border: 1px solid rgba(239,68,68,0.25); }

        .field label {
            display: block;
            font-size: 0.8rem;
            color: #9d7fc4;
            font-weight: 500;
            margin-bottom: 6px;
        }

        .field input {
            width: 100%;
            padding: 11px 14px;
            background: rgba(255,255,255,0.07);
            border: 1px solid rgba(168,85,247,0.3);
            border-radius: 10px;
            color: #f0e6ff;
            font-size: 0.9rem;
            outline: none;
            transition: border-color 0.18s, box-shadow 0.18s;
            margin-bottom: 20px;
        }

        .field input:focus {
            border-color: #a855f7;
            box-shadow: 0 0 0 3px rgba(168,85,247,0.15);
        }

        .field input::placeholder { color: #6b4f8a; }

        .submit-btn {
            width: 100%;
            padding: 12px;
            background: linear-gradient(135deg, #e879f9, #a855f7);
            border: none;
            border-radius: 10px;
            color: #fff;
            font-size: 0.95rem;
            font-weight: 600;
            cursor: pointer;
            transition: opacity 0.18s, transform 0.1s;
            box-shadow: 0 4px 20px rgba(168,85,247,0.35);
        }

        .submit-btn:hover { opacity: 0.9; }
        .submit-btn:active { transform: scale(0.98); }

        .back-link {
            display: block;
            text-align: center;
            margin-top: 18px;
            font-size: 0.82rem;
            color: #9d7fc4;
            text-decoration: none;
        }

        .back-link:hover { color: #e879f9; }
    </style>
</head>
<body>

    <div class="card">
        <div class="icon-wrap">🔐</div>
        <h2>Forgot Password</h2>
        <p class="subtitle">Enter your registered email address and we'll send you a 4-digit OTP to reset your password.</p>

        <% if (typeof query !== 'undefined' && query.error === 'email_not_found') { %>
            <div class="alert alert-error">⚠ No account found with this email address.</div>
        <% } %>

        <form action="/auth/forgot-password" method="POST">
            <div class="field">
                <label for="email">Email Address</label>
                <input type="email" id="email" name="email" placeholder="you@example.com" required />
            </div>
            <button type="submit" class="submit-btn">Send OTP</button>
        </form>

        <a href="/login" class="back-link">← Back to Login</a>
    </div>
    <script>
        window.addEventListener('pageshow', function(event) {
            if (event.persisted) {
                window.location.replace('/login');
            }
        });
    </script>
</body>
</html>
